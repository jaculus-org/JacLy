{
  "name": "jacly-monorepo",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@11.0.9",
  "scripts": {
    "prepare": "husky",
    "build": "turbo build",
    "build:watch": "turbo build:watch",
    "rebuild": "pnpm run clean-node && pnpm install && pnpm run build",
    "test": "turbo test",
    "lint": "turbo lint",
    "lint:fix": "biome lint --write",
    "format": "turbo format",
    "format:check": "turbo format:check",
    "check": "biome check --write",
    "type-check": "turbo type-check",
    "fix-all": "biome check --write",
    "check-all": "biome check && pnpm run build",
    "clean": "turbo clean && rm -rf node_modules/.turbo",
    "clean-node": "turbo clean-node && rm -rf node_modules",
    "test:prepare-registry": "node --experimental-strip-types test/data/runTsScriptTest.ts"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.15",
    "@commitlint/cli": "^21.0.0",
    "@commitlint/config-conventional": "^21.0.0",
    "@commitlint/types": "^21.0.0",
    "@jaculus/project": "^0.1.2",
    "@obsidize/tar-browserify": "^6.3.2",
    "@types/node": "^25.6.2",
    "@types/pako": "^2.0.4",
    "chai": "^6.2.2",
    "husky": "^9.1.7",
    "npm-check-updates": "^22.1.1",
    "pako": "^2.1.0",
    "turbo": "2.9.6"
  }
}
