{
  "name": "@jaculus/jacly-web",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "pnpm run paraglide:compile && pnpm run generate:schema && tsc -b && vite build",
    "paraglide:compile": "paraglide-js compile --project ./project.inlang --outdir ./src/core/paraglide",
    "generate:schema": "tsx scripts/generate-schema.ts",
    "type-check": "pnpm run paraglide:compile && tsc --noEmit",
    "type-check:watch": "tsc --noEmit --watch",
    "test": "pnpm run test:mocha",
    "test:mocha": "mocha",
    "test:playwright": "pnpm exec playwright test",
    "test:playwright:ui": "pnpm exec playwright test --ui",
    "preview": "vite preview",
    "lint": "biome lint .",
    "lint:fix": "biome lint --write .",
    "format": "biome format --write .",
    "format:check": "biome format .",
    "clean": "rm -rf dist *.tsbuildinfo .intlayer",
    "clean-node": "rm -rf node_modules"
  },
  "dependencies": {
    "@aziham/chartjs-plugin-streaming": "^3.5.1",
    "@base-ui/react": "^1.4.1",
    "@fontsource-variable/inter": "^5.2.8",
    "@hotjar/browser": "^1.0.9",
    "@jaculus/common": "workspace:*",
    "@jaculus/device": "workspace:*",
    "@jaculus/firmware": "workspace:*",
    "@jaculus/jacly": "workspace:*",
    "@jaculus/link": "workspace:*",
    "@jaculus/project": "workspace:*",
    "@jaculus/wokwi": "workspace:*",
    "@monaco-editor/react": "^4.7.0",
    "@sentry/react": "^10.52.0",
    "@tailwindcss/vite": "^4.3.0",
    "@tanstack/react-router": "^1.169.2",
    "@tanstack/react-router-devtools": "^1.166.13",
    "@wokwi/client": "^0.26.0",
    "@zenfs/archives": "^1.3.6",
    "@zenfs/core": "^2.5.6",
    "@zenfs/dom": "^1.2.9",
    "chart.js": "^4.5.1",
    "chartjs-adapter-luxon": "^1.3.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "dexie": "^4.4.2",
    "dexie-react-hooks": "^4.4.0",
    "esptool-js": "^0.6.0",
    "fflate": "^0.8.2",
    "flexlayout-react": "^0.9.1",
    "js-base64": "^3.7.8",
    "lucide-react": "^1.14.0",
    "marked": "^18.0.3",
    "nanoid": "^5.1.11",
    "notistack": "^3.0.2",
    "radix-ui": "^1.4.3",
    "react": "^19.2.6",
    "react-chartjs-2": "^5.3.1",
    "react-dom": "^19.2.6",
    "react-resizable-panels": "^4.11.0",
    "shadcn": "^4.7.0",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^4.3.0",
    "tw-animate-css": "^1.4.0",
    "vite": "^7.3.3",
    "workbox-window": "^7.4.1",
    "zustand": "^5.0.13"
  },
  "devDependencies": {
    "@inlang/paraglide-js": "^2.18.0",
    "@playwright/test": "^1.59.1",
    "@tailwindcss/typography": "^0.5.19",
    "@tanstack/router-plugin": "^1.167.35",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/w3c-web-serial": "^1.0.8",
    "@types/web-bluetooth": "^0.0.21",
    "@vitejs/plugin-react": "^5.2.0",
    "chai": "^6.2.2",
    "mocha": "^11.7.5",
    "tsx": "^4.21.0",
    "typescript": "~6.0.3",
    "vite-plugin-node-polyfills": "^0.25.0",
    "vite-plugin-pwa": "^1.3.0"
  }
}
