{
  "name": "@jaculus/jacly-web",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "pnpm run paraglide:compile && pnpm run generate:schema && tsc -b && vite build",
    "paraglide:compile": "paraglide-js compile --project ./project.inlang --outdir ./src/core/paraglide",
    "generate:schema": "tsx scripts/generate-schema.ts",
    "type-check": "pnpm run paraglide:compile && tsc --noEmit",
    "type-check:watch": "tsc --noEmit --watch",
    "test": "pnpm run test:mocha && pnpm run test:playwright",
    "test:mocha": "mocha",
    "test:playwright": "pnpm exec playwright test",
    "test:playwright:ui": "pnpm exec playwright test --ui",
    "preview": "vite preview",
    "lint": "biome lint .",
    "lint:fix": "biome lint --write .",
    "format": "biome format --write .",
    "format:check": "biome format .",
    "clean": "rm -rf dist *.tsbuildinfo .intlayer",
    "clean-node": "rm -rf node_modules"
  },
  "dependencies": {
    "@aziham/chartjs-plugin-streaming": "^3.5.1",
    "@base-ui/react": "^1.2.0",
    "@codingame/monaco-vscode-api": "^30.0.1",
    "@codingame/monaco-vscode-files-service-override": "^30.0.1",
    "@codingame/monaco-vscode-javascript-default-extension": "^30.0.1",
    "@codingame/monaco-vscode-json-default-extension": "^30.0.1",
    "@codingame/monaco-vscode-languages-service-override": "^30.0.1",
    "@codingame/monaco-vscode-model-service-override": "^30.0.1",
    "@codingame/monaco-vscode-textmate-service-override": "^30.0.1",
    "@codingame/monaco-vscode-theme-defaults-default-extension": "^30.0.1",
    "@codingame/monaco-vscode-theme-service-override": "^30.0.1",
    "@codingame/monaco-vscode-typescript-basics-default-extension": "^30.0.1",
    "@fontsource-variable/inter": "^5.2.8",
    "@jaculus/common": "workspace:*",
    "@jaculus/device": "workspace:*",
    "@jaculus/firmware": "workspace:*",
    "@jaculus/jacly": "workspace:*",
    "@jaculus/link": "workspace:*",
    "@jaculus/project": "workspace:*",
    "@sentry/react": "^10.48.0",
    "@tailwindcss/vite": "^4.2.1",
    "@tanstack/react-router": "^1.166.6",
    "@tanstack/react-router-devtools": "^1.166.6",
    "@wokwi/client": "^0.26.0",
    "@zenfs/archives": "^1.3.1",
    "@zenfs/core": "^2.5.2",
    "@zenfs/dom": "^1.2.7",
    "chart.js": "^4.5.1",
    "chartjs-adapter-luxon": "^1.3.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "dexie": "^4.3.0",
    "dexie-react-hooks": "^4.2.0",
    "esptool-js": "^0.5.7",
    "fflate": "^0.8.2",
    "flexlayout-react": "^0.8.19",
    "js-base64": "^3.7.8",
    "lucide-react": "^0.577.0",
    "monaco-editor": "npm:@codingame/monaco-vscode-editor-api@^30.0.1",
    "nanoid": "^5.1.6",
    "notistack": "^3.0.2",
    "radix-ui": "^1.4.3",
    "react": "^19.2.4",
    "react-chartjs-2": "^5.3.1",
    "react-dom": "^19.2.4",
    "react-resizable-panels": "^4.7.2",
    "shadcn": "^4.0.2",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^4.2.1",
    "tw-animate-css": "^1.4.0",
    "vite": "^7.3.1",
    "vscode": "npm:@codingame/monaco-vscode-extension-api@^30.0.1",
    "vscode-oniguruma": "^2.0.1",
    "vscode-textmate": "^9.3.2",
    "workbox-window": "^7.4.0",
    "zustand": "^5.0.11"
  },
  "devDependencies": {
    "@codingame/esbuild-import-meta-url-plugin": "^1.0.3",
    "@inlang/paraglide-js": "^2.14.0",
    "@playwright/test": "^1.58.2",
    "@tanstack/router-plugin": "^1.166.6",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/vscode": "^1.109.0",
    "@types/w3c-web-serial": "^1.0.8",
    "@types/web-bluetooth": "^0.0.21",
    "@vitejs/plugin-react": "^5.1.4",
    "chai": "^6.2.2",
    "mocha": "^11.7.5",
    "tsx": "^4.21.0",
    "typescript": "~5.9.3",
    "vite-plugin-node-polyfills": "^0.25.0",
    "vite-plugin-pwa": "^1.2.0"
  }
}
