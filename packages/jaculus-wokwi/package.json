{
  "name": "@jaculus/wokwi",
  "description": "Headless Wokwi simulator integration for Jaculus",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "files": [
    "dist",
    "README.md"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "dev": "vite build --watch",
    "build": "vite build",
    "build:watch": "vite build --watch",
    "type-check": "tsc --noEmit",
    "clean": "rm -rf dist *.tsbuildinfo",
    "clean-node": "pnpm clean && rm -rf node_modules"
  },
  "peerDependencies": {
    "@wokwi/client": "^0.26.0",
    "react": "^18.0.0 || ^19.0.0"
  },
  "dependencies": {
    "@jaculus/common": "workspace:*",
    "@jaculus/link": "workspace:*"
  },
  "devDependencies": {
    "@types/react": "^19.2.14",
    "@vitejs/plugin-react": "^5.1.4",
    "react": "^19.2.4",
    "typescript": "~5.9.3",
    "vite": "^7.3.1",
    "vite-plugin-dts": "^4.5.4"
  }
}
