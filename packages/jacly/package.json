{
  "name": "@jaculus/jacly",
  "description": "Jacly = Blockly editor for Jaculus",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "exports": {
    "./editor": {
      "types": "./dist/editor/index.d.ts",
      "import": "./dist/editor/index.js",
      "default": "./dist/editor/index.js"
    },
    "./schema": {
      "types": "./dist/schema/index.d.ts",
      "import": "./dist/schema/index.js",
      "default": "./dist/schema/index.js"
    },
    "./blocks": {
      "types": "./dist/blocks/index.d.ts",
      "import": "./dist/blocks/index.js",
      "default": "./dist/blocks/index.js"
    },
    "./toolbox": {
      "types": "./dist/toolbox/index.d.ts",
      "import": "./dist/toolbox/index.js",
      "default": "./dist/toolbox/index.js"
    },
    "./codegen": {
      "types": "./dist/codegen/index.d.ts",
      "import": "./dist/codegen/index.js",
      "default": "./dist/codegen/index.js"
    },
    "./workspace": {
      "types": "./dist/workspace/index.d.ts",
      "import": "./dist/workspace/index.js",
      "default": "./dist/workspace/index.js"
    },
    "./engine": {
      "types": "./dist/engine/index.d.ts",
      "import": "./dist/engine/index.js",
      "default": "./dist/engine/index.js"
    },
    "./project": {
      "types": "./dist/project/index.d.ts",
      "import": "./dist/project/index.js",
      "default": "./dist/project/index.js"
    },
    "./utils": {
      "types": "./dist/utils/index.d.ts",
      "import": "./dist/utils/index.js",
      "default": "./dist/utils/index.js"
    }
  },
  "scripts": {
    "dev": "vite build --watch",
    "build": "vite build && tsc --emitDeclarationOnly && tsc-alias",
    "build:watch": "vite build --watch",
    "type-check": "tsc --noEmit",
    "schema:gen": "tsx src/config/generate-schema.ts",
    "test": "pnpm run test:mocha",
    "test:mocha": "mocha",
    "test:playwright": "pnpm exec playwright test --config playwright.config.ts",
    "test:playwright:ui": "pnpm exec playwright test --config playwright.config.ts --ui",
    "clean": "rm -rf dist *.tsbuildinfo",
    "clean-node": "pnpm clean && rm -rf node_modules"
  },
  "peerDependencies": {
    "react": "^18.0.0 || ^19.0.0",
    "react-dom": "^18.0.0 || ^19.0.0"
  },
  "dependencies": {
    "@blockly/field-angle": "^6.0.9",
    "@blockly/field-colour": "^6.0.12",
    "@blockly/field-slider": "^8.0.9",
    "@blockly/plugin-cross-tab-copy-paste": "^8.0.8",
    "@blockly/workspace-backpack": "^7.0.11",
    "@jaculus/common": "workspace:*",
    "@jaculus/device": "workspace:*",
    "@jaculus/project": "workspace:*",
    "@kuband/react-blockly": "^10.0.1",
    "blockly": "^12.4.1",
    "lucide-react": "^0.577.0",
    "lucide-static": "^0.577.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@types/chai": "^5.2.3",
    "@types/mocha": "^10.0.10",
    "@types/node": "^25.4.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.4",
    "chai": "^6.2.2",
    "mocha": "^11.7.5",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "tsc-alias": "^1.8.17",
    "tsx": "^4.21.0",
    "typescript": "~5.9.3",
    "vite": "^7.3.3",
    "vite-plugin-dts": "^4.5.4",
    "vite-plugin-lib-inject-css": "^2.2.2"
  }
}
